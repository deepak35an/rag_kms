# Copy to project root on your VPS:
#   cp deploy/.env.vps.example .env
#
# Replace example.com with your real domain, then:
#   docker compose up -d --build
#
# IMPORTANT: NEXT_PUBLIC_API_URL is baked into the frontend at build time.
# After changing it, rebuild the frontend:
#   docker compose up -d --build frontend

# --- Production (after SSL / certbot) ---
NEXT_PUBLIC_API_URL=https://api.example.com

# --- Before SSL (HTTP-only nginx testing) ---
# NEXT_PUBLIC_API_URL=http://api.example.com

# --- Optional: Hugging Face token ---
# Default embedding model (all-MiniLM-L12-v2) works without this.
# Only needed if you switch to a gated HF model.
HF_TOKEN=
